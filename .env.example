# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Service role — для API аналитики и дашборда (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Dashboard — пароли через запятую (server-side)
# DASHBOARD_PASSWORDS=secret1,secret2
# DASHBOARD_JWT_SECRET — для подписи сессии (опционально, иначе используется SUPABASE_SERVICE_ROLE_KEY)

# Для теста аналитики локально — сохранять события с IP ::1/127.0.0.1
# ANALYTICS_INCLUDE_LOCAL=true
